diff --git a/kernel/main.c b/kernel/main.c
index a2c6c19..9c07621 100644
--- a/kernel/main.c
+++ b/kernel/main.c
@@ -34,7 +34,18 @@
 
 extern uint32_t kernel_end; 
 
-void kernel_main()
+#define MULTIBOOT_BOOTLOADER_MAGIC 0x2BADB002
+#define MULTIBOOT_INFO_MEMORY      0x00000001
+
+typedef struct multiboot_info
+{
+    uint32_t flags;
+    uint32_t mem_lower;
+    uint32_t mem_upper;
+    /* remaining fields not needed here */
+} multiboot_info_t;
+
+void kernel_main(uint32_t mb_magic, uint32_t mb_info_addr)
 {
     volatile char *v = (volatile char *)0xB8000;
     for (int i = 0; i < 80 * 25 * 2; i += 2)
@@ -57,9 +68,51 @@ void kernel_main()
 
     paging_init();
 
+    /*
+     * The heap end used to be a hardcoded 0x2800000 (40MB) regardless of
+     * how much RAM is actually installed - GRUB's multiboot info (which
+     * tells us exactly how much RAM is present via mem_upper) was being
+     * handed to us in EAX/EBX and then thrown away in boot.s before
+     * kernel_main was even called. On any machine/VM with less than
+     * ~40MB of RAM, the buddy allocator would happily hand out blocks
+     * that don't physically exist; writes to them are silently
+     * discarded instead of faulting, which corrupts whatever tries to
+     * use that memory (checkpoint's ~1MB snapshot allocation is the
+     * single largest allocation in the kernel, so it's the most likely
+     * thing to reach past real RAM and freeze the machine with no
+     * visible panic).
+     *
+     * Prefer the real detected memory size; only fall back to a small,
+     * conservative default if multiboot didn't hand us valid info at
+     * all (e.g. booted a non-multiboot-compliant way).
+     */
+    uint32_t desired_end = 0x2800000; /* 40MB, the previous assumption */
+    uint32_t detected_end = 0;
+
+    if (mb_magic == MULTIBOOT_BOOTLOADER_MAGIC && mb_info_addr)
+    {
+        multiboot_info_t *mbi = (multiboot_info_t *)mb_info_addr;
+        if (mbi->flags & MULTIBOOT_INFO_MEMORY)
+        {
+            /* mem_upper is KB of RAM above 1MB */
+            uint32_t total_ram = 0x100000 + mbi->mem_upper * 1024u;
+            /* leave a 1MB safety margin below the true top */
+            detected_end = total_ram > 0x100000 ? total_ram - 0x100000 : total_ram;
+        }
+    }
+
     uint32_t buddy_start = free_start + pmm_size;
-    uint32_t buddy_size = 0x2800000 - buddy_start;
-    buddy_init(buddy_start, buddy_size);
+    uint32_t buddy_end;
+
+    if (detected_end != 0)
+        buddy_end = (detected_end < desired_end) ? detected_end : desired_end;
+    else
+        buddy_end = buddy_start + 0x800000; /* unknown RAM: conservative 8MB heap */
+
+    if (buddy_end <= buddy_start)
+        buddy_end = buddy_start + 0x100000; /* absolute last-resort floor: 1MB */
+
+    buddy_init(buddy_start, buddy_end);
     slab_init_all();
     tracker_init();
     vfs_init();
